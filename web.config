<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- 1. API ve WebSocket isteklerini backend sunucusuna (Port 5000) yönlendir -->
        <rule name="CoreRemote-Backend" stopProcessing="true">
          <match url="^(api|socket.io|agent-socket|operator-socket)(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:5000/{R:0}" />
        </rule>

        <!-- 2. Geri kalan tüm istekleri Next.js Console'a (Port 3000) yönlendir -->
        <rule name="CoreRemote-Frontend" stopProcessing="true">
          <match url="(.*)" />
          <action type="Rewrite" url="http://127.0.0.1:3000/{R:0}" />
        </rule>
      </rules>
    </rewrite>
    
    <!-- IIS WebSocket modülünün proxy isteklerini kesintiye uğratmaması için aktif ediyoruz -->
    <webSocket enabled="true" />
  </system.webServer>
</configuration>
